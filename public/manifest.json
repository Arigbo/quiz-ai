{
  "manifest_version": 3,
  "name": "QuizSolver PRO AI",
  "version": "2.0.0",
  "description": "Expert AI assistant for analyzing and solving quizzes in real-time.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://quiz-ai-kappa.vercel.app/*"
  ],
  "action": {
    "default_title": "Open QuizSolver"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "favicon.ico",
    "48": "favicon.ico",
    "128": "favicon.ico"
  }
}