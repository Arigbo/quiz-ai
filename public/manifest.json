{
  "manifest_version": 3,
  "name": "QuizSolver AI PRO",
  "version": "2.0.0",
  "description": "Expert AI assistant for analyzing and solving quizzes on any webpage.",
  "permissions": ["sidePanel", "activeTab", "scripting"],
  "action": {
    "default_title": "Open QuizSolver Side Panel"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": ["<all_urls>"]
}