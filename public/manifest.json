{
  "manifest_version": 3,
  "name": "QuizSolver AI PRO",
  "version": "2.0.0",
  "description": "Expert testing assistant powered by Gemini AI.",
  "permissions": ["sidePanel", "activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open QuizSolver"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}